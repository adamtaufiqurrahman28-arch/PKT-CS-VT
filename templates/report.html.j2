<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>CrowdStrike Detection Report</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 32px; color: #222; }
    h1, h2 { margin-bottom: 8px; }
    .muted { color: #666; }
    .cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin: 20px 0; }
    .card { border: 1px solid #ddd; padding: 12px; border-radius: 6px; }
    .label { color: #666; font-size: 12px; }
    .value { font-size: 24px; margin-top: 6px; }
    table { border-collapse: collapse; width: 100%; margin-top: 16px; font-size: 13px; }
    th, td { border: 1px solid #ddd; padding: 8px; text-align: left; vertical-align: top; }
    th { background: #f3f3f3; }
  </style>
</head>
<body>
  <h1>CrowdStrike Detection Report</h1>
  <p class="muted">Period: Last {{ days }} days. SHA256 is intentionally hidden from this report.</p>

  <div class="cards">
    <div class="card"><div class="label">Detection rows</div><div class="value">{{ summary.total_detection_rows }}</div></div>
    <div class="card"><div class="label">Detection count</div><div class="value">{{ summary.total_detection_count }}</div></div>
    <div class="card"><div class="label">VT found</div><div class="value">{{ summary.vt_found }}</div></div>
    <div class="card"><div class="label">VT malicious</div><div class="value">{{ summary.malicious_sum }}</div></div>
  </div>

  <h2>Summary</h2>
  <p>Top detected object: <strong>{{ summary.top_file }}</strong></p>
  <p>VT not found: {{ summary.vt_not_found }} | VT error: {{ summary.vt_error }} | VT suspicious: {{ summary.suspicious_sum }}</p>

  <h2>Detection Details</h2>
  {% if rows %}
  <table>
    <thead>
      <tr>
        {% for key in rows[0].keys() %}
        <th>{{ key }}</th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for row in rows %}
      <tr>
        {% for value in row.values() %}
        <td>{{ value }}</td>
        {% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p>No detection data was returned.</p>
  {% endif %}
</body>
</html>
